@page "/"
@page "/search"
@using Shared.Model
@using System.Text.Json
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Search</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;600&family=Google+Sans+Text:wght@400;500&display=swap');

    :root {
        --bg-primary: #1a1a2e;
        --bg-secondary: #16213e;
        --bg-card: #1e2a4a;
        --bg-input: #0f1629;
        --accent: #8ab4f8;
        --accent-hover: #aecbfa;
        --accent-dim: rgba(138, 180, 248, 0.08);
        --text-primary: #e8eaed;
        --text-secondary: #9aa0a6;
        --text-dim: #5f6368;
        --border: rgba(138, 180, 248, 0.12);
        --border-active: rgba(138, 180, 248, 0.4);
        --success: #81c995;
        --warning: #fdd663;
        --radius-md: 16px;
        --radius-xl: 28px;
        --radius-pill: 100px;
        --transition-med: 250ms cubic-bezier(0.4, 0, 0.2, 1);
    }

    .search-page {
        font-family: 'Google Sans Text', sans-serif;
        min-height: 100vh;
        background: var(--bg-primary);
        color: var(--text-primary);
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 60px;
    }

    .search-brand h1 {
        font-family: 'Google Sans', sans-serif;
        font-size: 3.5rem;
        background: linear-gradient(135deg, var(--accent) 0%, #81c995 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 8px;
    }

    .tabs {
        display: flex;
        gap: 12px;
        margin-bottom: 32px;
    }

    .tab-btn {
        padding: 10px 24px;
        border-radius: var(--radius-pill);
        border: 1px solid var(--border);
        background: rgba(255,255,255,0.05);
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.2s;
        font-size: 0.9rem;
    }

    .tab-btn.active {
        background: var(--accent-dim);
        border-color: var(--accent);
        color: var(--accent);
    }

    .search-container {
        width: 100%;
        max-width: 700px;
        padding: 0 20px;
    }

    .search-input-wrapper {
        display: flex;
        background: var(--bg-input);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-xl);
        padding: 6px 10px 6px 20px;
        align-items: center;
        transition: var(--transition-med);
    }

    .search-input-wrapper:focus-within {
        border-color: var(--accent);
        box-shadow: 0 0 20px rgba(138, 180, 248, 0.1);
    }

    .search-input {
        flex: 1;
        background: none;
        border: none;
        color: white;
        font-size: 1.1rem;
        outline: none;
        padding: 10px;
    }

    .search-btn {
        background: var(--accent);
        border: none;
        border-radius: 50%;
        width: 44px;
        height: 44px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s;
    }

    .agent-form {
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 30px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .form-input {
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 14px;
        color: white;
        outline: none;
    }

    .activate-btn {
        background: var(--accent);
        color: #000;
        font-weight: 600;
        padding: 14px;
        border-radius: 12px;
        border: none;
        cursor: pointer;
    }

    .results-list {
        margin-top: 30px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding-bottom: 50px;
    }

    .result-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 20px;
    }

    .result-url {
        color: var(--accent);
        font-weight: 500;
        font-size: 1rem;
        word-break: break-all;
        display: block;
        margin-bottom: 10px;
    }

    .result-meta {
        display: flex;
        gap: 15px;
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    .toggle-container {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 15px;
        padding-left: 10px;
        cursor: pointer;
    }

    .switch {
        width: 34px;
        height: 18px;
        border-radius: 10px;
        position: relative;
        transition: 0.3s;
    }

    .slider {
        width: 14px;
        height: 14px;
        background: white;
        border-radius: 50%;
        position: absolute;
        top: 2px;
        transition: 0.3s;
    }

    /* Animation Container */
    .status-overlay {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 1000;
        pointer-events: none;
    }

    /* 3D Paper Plane */
    .paper-plane {
        font-size: 80px;
        display: inline-block;
        animation: fly-away 1.5s ease-in forwards;
    }

    @@keyframes fly-away {
        0%   { transform: translate(0, 0) rotate(0deg) scale(1); opacity: 1; }
        20%  { transform: translate(-20px, 20px) rotate(-10deg) scale(1.1); }
        100% { transform: translate(600px, -400px) rotate(15deg) scale(0); opacity: 0; }
    }

    /* Error Message */
    .error-msg {
        background: #f28b82;
        color: #3c1e1e;
        padding: 12px 24px;
        border-radius: var(--radius-md);
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        font-weight: 500;
        animation: shake 0.4s ease-in-out;
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        25%       { transform: translateX(-5px); }
        75%       { transform: translateX(5px); }
    }
</style>

<div class="search-page">
    <div class="search-brand">
        <h1>SearchEngine</h1>
    </div>

    <div class="tabs">
        <button class="tab-btn @(activeTab == "search" ? "active" : "")" @onclick='() => activeTab = "search"'>Search</button>
        <button class="tab-btn @(activeTab == "agent" ? "active" : "")" @onclick='() => activeTab = "agent"'>Search Agent</button>
    </div>

    <div class="search-container">
        @if (activeTab == "search")
        {
            <div class="search-input-wrapper">
                <input class="search-input" @bind="inputText" @onkeydown="HandleKeyDown" placeholder="What are you looking for?"/>
                <button class="search-btn" @onclick="ExecuteSearch">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
            </div>

            <div class="toggle-container" @onclick="ToggleCaseSensitive">
                <div class="switch" style="background: @(caseSensitive ? "var(--accent)" : "#333");">
                    <div class="slider" style="left: @(caseSensitive ? "18px" : "2px");"></div>
                </div>
                <span style="font-size: 0.85rem; color: var(--text-secondary);">Case-sensitive: @(caseSensitive ? "On" : "Off")</span>
            </div>

            @if (isLoading)
            {
                <p style="text-align: center; margin-top: 40px; color: var(--accent);">Søger...</p>
            }
            else if (result != null)
            {
                @if (result.DocumentHits != null && result.DocumentHits.Any())
                {
                    <div class="results-list">
                        @foreach (var doc in result.DocumentHits)
                        {
                            <div class="result-card">
                                <span class="result-url">@doc.Document.mUrl</span>
                                <div class="result-meta">
                                    <span>@doc.NoOfHits hits</span>
                                    <span>•</span>
                                    <span>Indexed: @doc.Document.mIdxTime</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="text-align: center; margin-top: 40px;">
                        <p style="color: var(--text-secondary);">Ingen resultater fundet for "@lastSearchQuery".</p>
                    </div>
                }
            }
        }
        else
        {
            <div class="agent-form">
                <div class="form-group">
                    <label>Word to keep an eye on</label>
                    <input class="form-input" placeholder="e.g., Name, Numberplate, Phonenumber..." @bind="agentKeywords" />
                </div>
                <div class="form-group">
                    <label>Your Email</label>
                    <input class="form-input" placeholder="name@domain.com" @bind="agentEmail" />
                </div>
                <button class="activate-btn" @onclick="ActivateAgent">Activate Agent</button>
            </div>
        }
    </div>

    @if (showPlane)
    {
        <div class="status-overlay">
            <div class="paper-plane">
                <svg width="80" height="80" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21.707 2.293a1 1 0 0 0-1.057-.225l-18 7a1 1 0 0 0 .026 1.877l5.324 1.775 2.21 6.63A1 1 0 0 0 11.16 20h.01a1 1 0 0 0 .836-.452l2.328-3.493 4.382 2.928A1 1 0 0 0 20 19a1 1 0 0 0 .97-.757l2-14a1 1 0 0 0-.263-.95zM18.1 6.431l-7.531 6.024-3.464-1.154zm-.653 10.417-3.676-2.455 3.097-4.648zm-5.96-.75L9.74 12.88l7.035-5.628z"/>
                </svg>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="status-overlay">
            <div class="error-msg">
                <span>⚠️ @errorMessage</span>
            </div>
        </div>
    }
</div>

@code {
    private string activeTab = "search";
    private string inputText = "";
    private string lastSearchQuery = "";
    private bool isLoading = false;
    private bool caseSensitive = false;
    private SearchResult? result = null;
    private string agentKeywords = "";
    private string agentEmail = "";

    private bool showPlane = false;
    private string errorMessage = "";

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ExecuteSearch();
    }

    private void ToggleCaseSensitive() => caseSensitive = !caseSensitive;

    private async Task ExecuteSearch()
    {
        if (string.IsNullOrWhiteSpace(inputText)) return;

        isLoading = true;
        result = null;
        lastSearchQuery = inputText;

        try
        {
            var request = new SearchRequest
            {
                Query = inputText.Split(' ', StringSplitOptions.RemoveEmptyEntries),
                MaxAmount = 20,
                CaseSensitive = caseSensitive
            };

            var response = await Http.PostAsJsonAsync("http://localhost:5190/api/orchestrator/search", request);
            if (response.IsSuccessStatusCode)
            {
                result = await response.Content.ReadFromJsonAsync<SearchResult>(new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fejl under søgning: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ActivateAgent()
    {
        if (string.IsNullOrWhiteSpace(agentKeywords) || string.IsNullOrWhiteSpace(agentEmail))
        {
            ShowError("Udfyld venligst begge felter.");
            return;
        }

        try
        {
            var agent = new
            {
                email = agentEmail,
                searchWords = agentKeywords.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            };

            var response = await Http.PostAsJsonAsync("http://localhost:5190/api/orchestrator/agents", agent);

            if (response.IsSuccessStatusCode)
            {
                showPlane = true;
                agentKeywords = "";
                agentEmail = "";
                errorMessage = "";

                StateHasChanged();

                await Task.Delay(1500);
                showPlane = false;
            }
            else
            {
                ShowError("Kunne ikke oprette agent. Prøv igen senere.");
            }
        }
        catch (Exception ex)
        {
            ShowError($"Forbindelsesfejl: {ex.Message}");
        }
    }

    private async void ShowError(string msg)
    {
        errorMessage = msg;
        StateHasChanged();
        await Task.Delay(4000);
        errorMessage = "";
        StateHasChanged();
    }
}